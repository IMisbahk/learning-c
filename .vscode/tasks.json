{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run C",
            "type": "shell",
            "command": "mkdir -p ${fileDirname}/../executables && gcc",
            "args": [
                "-Wall",
                "${file}",
                "-o",
                "${fileDirname}/../executables/${fileBasenameNoExtension}",
                "&&",
                "${fileDirname}/../executables/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}